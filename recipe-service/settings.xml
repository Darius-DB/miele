<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0">
    <!--
      Credentials come from GitLab CI/CD variables
      (Project Settings -> CI/CD -> Variables):
        ARTIFACTORY_USER      (Masked)
        ARTIFACTORY_PASSWORD  (Masked, Protected)
      The <id> values MUST match the <id> values in pom.xml's
      <distributionManagement> section.
    -->
    <servers>
        <server>
            <id>miele-artifactory-releases</id>
            <username>${env.ARTIFACTORY_USER}</username>
            <password>${env.ARTIFACTORY_PASSWORD}</password>
        </server>
        <server>
            <id>miele-artifactory-snapshots</id>
            <username>${env.ARTIFACTORY_USER}</username>
            <password>${env.ARTIFACTORY_PASSWORD}</password>
        </server>
    </servers>
</settings>